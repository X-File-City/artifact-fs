              "path": "internal/hydrator/hydrator.go",
              "type": "file"
            },
            {
              "path": "internal/hydrator/inflight.go",
              "type": "file"
            }
          ],
          "opacity": 0.8,
          "renderStrategy": "border"
        }
      ],
      "colorMode": "fileTypes"
    },
    {
      "id": "step-6-persistence",
      "title": "State & Persistence",
      "description": "Four packages hold state. The git store wraps the bare repository. A metadata layer backed by SQLite tracks per-repository state and hydration progress. The overlay captures local writes so the mount behaves like a mutable working tree on top of the read-only git view. A snapshot store preserves consistent views for status and diff operations.",
      "estimatedTime": 120,
      "focusDirectory": "internal",
      "highlightLayers": [
        {
          "id": "persistence-layer",
          "name": "State Stores",
