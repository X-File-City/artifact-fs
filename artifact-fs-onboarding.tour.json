            { "path": "e2e_setup_linux_test.go", "type": "file" },
            { "path": "bench_test.go", "type": "file" }
          ],
          "opacity": 0.75,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "step-8-support",
      "title": "Supporting Packages",
      "description": "The smaller packages round out the system. Shared data structures and canonical interfaces live in the model package. A watcher polls the gitdir to react to HEAD changes. An auth helper scrubs credentials out of log lines before they're emitted. And the logging package provides the structured JSON logger used across the daemon.",
      "estimatedTime": 90,
      "focusDirectory": "internal",
      "colorMode": "fileTypes",
      "highlightLayers": [
