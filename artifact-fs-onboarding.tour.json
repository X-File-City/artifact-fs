        }
      ],
      "colorMode": "fileTypes"
    },
    {
      "id": "step-5-hydration",
      "title": "Lazy Blob Hydration",
      "description": "The hydrator manages background blob fetching. A worker pool keeps long-lived git batch processes ready to stream blobs on demand, with concurrency tunable at the command line. A separate in-flight tracker deduplicates concurrent requests for the same blob, so even under heavy parallel reads each blob is fetched only once.",
      "estimatedTime": 120,
      "focusDirectory": "internal/hydrator",
      "highlightLayers": [
        {
          "id": "hydration-files",
          "name": "Hydration Pipeline",
          "color": "#ef4444",
          "items": [
