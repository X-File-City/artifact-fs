    {
      "id": "step-2-entry-point",
      "title": "CLI Entry Point",
      "description": "The binary is built from a tiny entry point that immediately delegates into the CLI package. The CLI parses the user-facing subcommands for adding a repository, starting the daemon, checking status, and removing a repository, and wires each one into the daemon and registry.",
      "estimatedTime": 60,
      "focusDirectory": "",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "entry-layer",
          "name": "Entry Point & CLI",
          "color": "#3b82f6",
          "items": [
            { "path": "cmd/artifact-fs/main.go", "type": "file" },
            { "path": "internal/cli/cli.go", "type": "file" }
          ],
          "opacity": 0.8,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "step-3-orchestration",
      "title": "Daemon & Registry",
      "description": "The orchestration layer owns the long-running daemon lifecycle and the registry of mounted repositories. The daemon coordinates mount, refresh, and shutdown. The registry is the SQLite-backed source of truth for which repos are known and where they're configured to mount.",
      "estimatedTime": 90,
      "focusDirectory": "internal",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "orchestration-layer",
          "name": "Orchestration",
          "color": "#10b981",
          "items": [
            { "path": "internal/daemon/daemon.go", "type": "file" },
            { "path": "internal/registry/registry.go", "type": "file" }
          ],
          "opacity": 0.75,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "step-4-fuse",
      "title": "FUSE Filesystem Layer",
      "description": "The FUSE layer is where the operating system meets the repository. One file dispatches kernel callbacks, another composes the snapshot of the git tree with the overlay of local writes into a single read-through view, and platform-specific mount logic is split cleanly between macOS and Linux.",
      "estimatedTime": 120,
      "focusDirectory": "internal/fusefs",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "fuse-core",
          "name": "FUSE Core",
          "color": "#f59e0b",
          "items": [
            { "path": "internal/fusefs/ops.go", "type": "file" },
            { "path": "internal/fusefs/merged.go", "type": "file" },
            { "path": "internal/fusefs/fuse_darwin.go", "type": "file" },
            { "path": "internal/fusefs/fuse_linux.go", "type": "file" }
          ],
          "opacity": 0.8,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "step-5-hydration",
      "title": "Lazy Blob Hydration",
      "description": "The hydrator manages background blob fetching. A worker pool keeps long-lived git batch processes ready to stream blobs on demand, with concurrency tunable at the command line. A separate in-flight tracker deduplicates concurrent requests so each blob is fetched exactly once even under heavy parallel reads.",
      "estimatedTime": 90,
      "focusDirectory": "internal/hydrator",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "hydration-files",
          "name": "Hydration Pipeline",
          "color": "#ef4444",
          "items": [
            { "path": "internal/hydrator/hydrator.go", "type": "file" },
            { "path": "internal/hydrator/inflight.go", "type": "file" }
          ],
          "opacity": 0.8,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "step-6-persistence",
      "title": "State & Persistence",
      "description": "Four packages hold state. The git store wraps the bare repository. The snapshot store preserves consistent tree views keyed by generation. The overlay captures local writes so the mount behaves like a mutable working tree on top of the read-only git view. A shared SQLite helper underpins the metadata.",
      "estimatedTime": 120,
      "focusDirectory": "internal",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "persistence-layer",
          "name": "State Stores",
          "color": "#06b6d4",
          "items": [
            { "path": "internal/gitstore/gitstore.go", "type": "file" },
            { "path": "internal/snapshot/store.go", "type": "file" },
            { "path": "internal/overlay/store.go", "type": "file" },
            { "path": "internal/meta/sqlite.go", "type": "file" }
          ],
          "opacity": 0.75,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "step-7-tests",
      "title": "End-to-End Tests & Benchmarks",
      "description": "The root-level end-to-end tests exercise the full daemon against real FUSE mounts, with platform-specific setup kept in separate files so each platform's quirks stay isolated. The benchmark suites capture performance baselines — essential reading before tuning hydration or the filesystem layer.",
      "estimatedTime": 90,
      "focusDirectory": "",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "test-layer",
          "name": "E2E & Benchmark Tests",
          "color": "#eab308",
          "items": [
            { "path": "e2e_test.go", "type": "file" },
