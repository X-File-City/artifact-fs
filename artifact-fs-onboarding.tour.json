    {
      "id": "step-4-fuse",
      "title": "FUSE Filesystem Layer",
      "description": "This is where the FUSE operations live. One file handles the kernel operation callbacks, another implements the merged read-through view that combines the git tree with local writes, and platform-specific mount logic is split cleanly between macOS and Linux. This is how the operating system sees the repository tree immediately while contents stream in behind the scenes.",
      "estimatedTime": 120,
      "focusDirectory": "internal/fusefs",
      "highlightLayers": [
        {
          "id": "fuse-core",
          "name": "FUSE Core",
          "color": "#8b5cf6",
