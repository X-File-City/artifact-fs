{
  "id": "artifact-fs-onboarding",
  "title": "ArtifactFS Onboarding Tour",
  "description": "A guided walkthrough of ArtifactFS — a Git-backed FUSE filesystem daemon in Go that mounts repositories as working trees and hydrates file contents on demand.",
  "version": "1.0.0",
  "audience": "New Contributors",
  "prerequisites": [
    "Familiarity with Go",
    "Basic understanding of FUSE and Git internals"
  ],
  "steps": [
    {
      "id": "step-1-overview",
      "title": "Project Overview",
      "description": "Welcome to ArtifactFS. It's a Go module that ships a single command-line tool which registers repositories, runs a FUSE daemon, and hydrates blobs lazily. Start here with a view of the whole project — the five subsystems that cooperate to present a git repo as a live filesystem are grouped by color.",
